#include <stdio.h>

int main() {
    int n, sum = 0;
    printf("Enter N: ");
    scanf("%d", &n);
    
    sum = n * (n + 1) / 2;
    printf("Sum of first %d natural numbers = %d\n", n, sum);
    return 0;
}


#include <stdio.h>

int main() {
    int n, fact = 1;
    printf("Enter number: ");
    scanf("%d", &n);
    
    for(int i = 1; i <= n; i++) {
        fact *= i;
    }
    
    printf("Factorial of %d = %d\n", n, fact);
    return 0;
}
