#include <stdio.h>

int main() {
    int num, sum = 0;
    printf("Enter number: ");
    scanf("%d", &num);
    
    int temp = num;
    while(temp != 0) {
        sum += temp % 10;
        temp /= 10;
    }
    
    printf("Sum of digits of %d = %d\n", num, sum);
    return 0;
}





#include <stdio.h>

int main() {
    int num, rev = 0;
    printf("Enter number: ");
    scanf("%d", &num);
    
    int temp = num;
    while(temp != 0) {
        rev = rev * 10 + (temp % 10);
        temp /= 10;
    }
    
    printf("Reverse of %d = %d\n", num, rev);
    return 0;
}





#include <stdio.h>

int main() {
    int num, product = 1;
    printf("Enter number: ");
    scanf("%d", &num);
    
    int temp = num;
    while(temp != 0) {
        product *= temp % 10;
        temp /= 10;
    }
    
    printf("Product of digits of %d = %d\n", num, product);
    return 0;
}





#include <stdio.h>

int main() {
    int num, rev = 0, temp;
    printf("Enter number: ");
    scanf("%d", &num);
    
    temp = num;
    while(temp != 0) {
        rev = rev * 10 + (temp % 10);
        temp /= 10;
    }
    
    if(num == rev)
        printf("%d is a palindrome\n", num);
    else
        printf("%d is not a palindrome\n", num);
    
    return 0;
}
